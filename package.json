{
  "name": "shop-aws-cloudfront",
  "version": "0.1.0",
  "bin": {
    "shop-aws-cloudfront": "bin/shop-aws-cloudfront.js"
  },
  "scripts": {
    "fillTables": "tsx scripts/fill-tables.ts",
    "build": "tsx scripts/build.ts",
    "predeploy": "npm run build",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:product": "cdk deploy ProductServiceStack --require-approval never",
    "deploy:import": "cdk deploy ImportServiceStack --require-approval never",
    "presynth": "npm run build",
    "synth": "cdk synth",
    "test": "jest",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30",
    "@types/node": "^24.12.2",
    "@types/uuid": "^10.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-cdk": "2.1117.0",
    "esbuild": "^0.28.0",
    "jest": "^30",
    "prettier": "^3.8.3",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "aws-cdk-lib": "^2.247.0",
    "constructs": "^10.5.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.4.1",
    "uuid": "^14.0.0"
  }
